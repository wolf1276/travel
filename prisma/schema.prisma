generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum PlaceStatus {
  WANT_TO_VISIT
  VISITED
}

enum CoupleInviteStatus {
  PENDING
  ACCEPTED
  REVOKED
}

enum NotificationType {
  PLACE_ADDED
}

/// Mirrors the Supabase `auth.users` row for the same id. Created on first
/// sign-in (see lib/auth.ts). Kept separate from auth.users so app-specific
/// profile fields can evolve without touching Supabase's managed table.
model User {
  id          String   @id
  email       String   @unique
  displayName String?  @map("display_name")
  avatarUrl   String?  @map("avatar_url")
  bio         String?
  coupleId    String   @map("couple_id")
  couple      Couple   @relation(fields: [coupleId], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  createdPlaces Place[]
  visits        Visit[]
  photos        Photo[]
  tags          Tag[]

  sentInvites     CoupleInvite[] @relation("InvitesSent")
  acceptedInvites CoupleInvite[] @relation("InvitesAccepted")

  notifications          Notification[] @relation("NotificationRecipient")
  triggeredNotifications Notification[] @relation("NotificationActor")

  @@map("users")
}

/// Exactly two Users share one Couple. A solo Couple is created for every
/// User on first sign-in (see lib/auth.ts); accepting a CoupleInvite moves
/// the accepting User into the inviter's Couple. Places are owned by Couple
/// (see Place.coupleId); Visit/Photo/Tag still belong to the acting User.
model Couple {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")

  members User[]
  invites CoupleInvite[]
  places  Place[]

  @@map("couples")
}

/// A one-time shareable link a User sends their partner. Accepting it moves
/// the accepting User into the inviter's Couple (see
/// app/api/couple/invites/[token]/accept/route.ts). Only one PENDING invite
/// is kept active per Couple at a time.
model CoupleInvite {
  id           String             @id @default(uuid())
  coupleId     String             @map("couple_id")
  couple       Couple             @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  invitedById  String             @map("invited_by_id")
  invitedBy    User               @relation("InvitesSent", fields: [invitedById], references: [id], onDelete: Cascade)
  token        String             @unique
  status       CoupleInviteStatus @default(PENDING)
  expiresAt    DateTime           @map("expires_at")
  acceptedById String?            @map("accepted_by_id")
  acceptedBy   User?              @relation("InvitesAccepted", fields: [acceptedById], references: [id])
  createdAt    DateTime           @default(now()) @map("created_at")

  @@index([coupleId])
  @@map("couple_invites")
}

/// A saved place shared by a Couple - any location worth visiting together
/// (cafe, restaurant, beach, viewpoint, museum, hidden spot, ...), not just
/// travel destinations. Doubles as a "want to visit" wishlist item until it
/// gains a Visit, at which point status flips to VISITED and the same
/// record becomes the anchor for the memory scrapbook view. createdById is
/// kept purely for attribution ("added by ...") - access is controlled by
/// coupleId, so either partner can read/edit/delete any place regardless of
/// who added it. country/countryCode are best-effort, auto-filled from the
/// location provider when available - never required.
model Place {
  id              String      @id @default(uuid())
  coupleId        String      @map("couple_id")
  couple          Couple      @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  createdById     String      @map("created_by_id")
  createdBy       User        @relation(fields: [createdById], references: [id], onDelete: Cascade)
  name            String
  address         String?
  country         String?
  countryCode     String?     @map("country_code")
  placeProviderId String?     @map("place_provider_id")
  latitude        Float?
  longitude       Float?
  coverImageUrl   String?     @map("cover_image_url")
  coverImagePath  String?     @map("cover_image_path")
  dreamNotes      String?     @map("dream_notes")
  personalReason  String?     @map("personal_reason")
  status          PlaceStatus @default(WANT_TO_VISIT)
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  tags          PlaceTag[]
  visits        Visit[]
  notifications Notification[]

  @@index([coupleId, status])
  @@map("places")
}

/// A completed visit to a Place. Modelled separately from Place (rather than
/// flattening visit fields onto Place) so a future "Trips"/travel-recap
/// feature can attach multiple visits to the same place without a migration.
model Visit {
  id        String   @id @default(uuid())
  placeId   String   @map("place_id")
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  visitDate DateTime @map("visit_date")
  rating    Int?
  journal   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  photos Photo[]

  @@index([placeId])
  @@index([userId])
  @@map("visits")
}

model Photo {
  id          String   @id @default(uuid())
  visitId     String   @map("visit_id")
  visit       Visit    @relation(fields: [visitId], references: [id], onDelete: Cascade)
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  url         String
  storagePath String   @map("storage_path")
  width       Int?
  height      Int?
  isFavorite  Boolean  @default(false) @map("is_favorite")
  caption     String?
  position    Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([visitId])
  @@index([userId])
  @@map("photos")
}

model Tag {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  places PlaceTag[]

  @@unique([userId, name])
  @@map("tags")
}

model PlaceTag {
  placeId String @map("place_id")
  place   Place  @relation(fields: [placeId], references: [id], onDelete: Cascade)
  tagId   String @map("tag_id")
  tag     Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([placeId, tagId])
  @@map("place_tags")
}

/// An in-app notification for one User, e.g. "<partner> added a new place."
/// Currently only fired when a partner adds a Place (see POST
/// /api/places) - actorId is who triggered it, userId is the recipient.
/// placeId lets the notification deep-link straight to the place.
model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  user      User             @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actorId   String?          @map("actor_id")
  actor     User?            @relation("NotificationActor", fields: [actorId], references: [id], onDelete: Cascade)
  type      NotificationType @default(PLACE_ADDED)
  placeId   String?          @map("place_id")
  place     Place?           @relation(fields: [placeId], references: [id], onDelete: Cascade)
  message   String
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  @@index([userId, isRead])
  @@map("notifications")
}
