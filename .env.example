# Supabase (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Postgres connection (Project Settings -> Database -> Connect)
# The direct connection (db.<ref>.supabase.co:5432) only resolves over IPv6 -
# on an IPv4-only network use the Supavisor pooler for both instead:
#   DATABASE_URL: transaction pooler, port 6543, with ?pgbouncer=true
#   DIRECT_URL:   session pooler, port 5432 (used by `prisma migrate`)
# Both use username "postgres.<project-ref>" (not just "postgres") on the pooler.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-<n>-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.<project-ref>:<password>@aws-<n>-<region>.pooler.supabase.com:5432/postgres

# Supabase Storage bucket used for photo uploads (create it as a public bucket named "photos")
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=photos

# Mapbox (account.mapbox.com -> Tokens)
NEXT_PUBLIC_MAPBOX_TOKEN=
